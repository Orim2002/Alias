{
  "name": "alias-game",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "concurrently \"pnpm --filter server dev\" \"pnpm --filter client dev\"",
    "build": "pnpm --filter @alias/shared build && pnpm --filter client build && pnpm --filter server build",
    "start": "node apps/server/dist/index.js",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5"
  }
}
